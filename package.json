{
  "name": "@aurora-mcp/sdk",
  "version": "0.1.0",
  "description": "SDK TypeScript oficial pra Aurora MCP — 16 especialistas de engenharia + catálogo curado + playbooks privados.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "import": "./dist/oauth/index.js",
      "require": "./dist/oauth/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["aurora", "mcp", "ai", "agents", "claude", "llm", "sdk"],
  "author": "Aurora MCP — adeiltonpessini",
  "license": "MIT",
  "homepage": "https://app.aurora-mcp.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adeiltonpessini/aurora-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/adeiltonpessini/aurora-sdk-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
